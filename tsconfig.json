{
  "compilerOptions": {
    "module": "preserve",
    "target": "esnext",
    "types": [],
    "declaration": true,
    "noEmit": true,
    "outDir": "dist",
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "jsx": "preserve",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "paths": {
        "@typescript-eslint/eslint-plugin/dist": ["./node_modules/@typescript-eslint/eslint-plugin/dist/index.d.ts"],
    }
  },
  "include": [
    "src/**/*",
    "*.ts",
    "*.js"
  ],
  "exclude": [
    "index.js",
    "node_modules"
  ]
}
